{
  "name": "@farsight-cda/rpc-sdk",
  "version": "1.0.0",
  "description": "SDK for reading Farsight RPC provider configuration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "farsight",
    "rpc",
    "sdk",
    "typescript"
  ],
  "author": "Farsight",
  "repository": {
    "type": "git",
    "url": "https://github.com/Farsight-CDA/Farsight.Rpc"
  },
  "license": "UNLICENSED"
}
