@page
@model Farsight.RPC.Providers.Pages.LoginModel
@{
    Layout = "Shared/_Layout";
    ViewData["Title"] = "Login";
}

<div class="panel" style="max-width: 420px; margin: 3rem auto;">
    <h1>Admin Login</h1>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="message error">@Model.ErrorMessage</div>
    }
    <form method="post">
        <div class="field">
            <label asp-for="Input.UserName"></label>
            <input asp-for="Input.UserName" autocomplete="username" />
        </div>
        <div class="field">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
        </div>
        <button class="button" type="submit">Sign in</button>
    </form>
</div>
