@page
@model Farsight.RPC.Api.Pages.Chains.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Chains";
    ViewData["ActivePage"] = "Chains";
}

<div class="actions" style="margin-bottom: 1rem;">
    <a class="button secondary" asp-page="/Index">← Back to Home</a>
</div>

<div class="panel">
    <h1>Chains</h1>
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="message @(Model.StatusIsError ? "error" : "success")">@Model.StatusMessage</div>
    }
    <form method="post" class="actions">
        <input asp-for="Name" placeholder="chain name (saved as lowercase)" />
        <button class="button" type="submit">Add</button>
    </form>
</div>

<table>
<thead><tr><th>Name</th><th style="text-align: right;">Actions</th></tr></thead>
<tbody>
@foreach (var item in Model.Items)
{
    <tr>
        <td>@item.Name</td>
        <td style="text-align: right;">
            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display: inline;" onsubmit="return confirm('Delete this chain?');">
                <button type="submit" class="button danger" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;">Remove</button>
            </form>
        </td>
    </tr>
}
</tbody>
</table>
