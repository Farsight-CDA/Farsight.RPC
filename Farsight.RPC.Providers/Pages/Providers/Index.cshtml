@page
@model Farsight.RPC.Providers.Pages.Providers.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Providers";
    ViewData["ActivePage"] = "Providers";
}

<div class="actions" style="margin-bottom: 1rem;">
    <a class="button secondary" asp-page="/Index">← Back to Home</a>
</div>

<div class="panel">
    <h1>Provider Rows</h1>
    <form method="get" class="grid">
        <div class="field">
            <label>Application</label>
            <select asp-for="Query.ApplicationId">
                <option value="">Select application</option>
                @foreach (var item in Model.Applications)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </div>
        <div class="field">
            <label>Environment</label>
            <select asp-for="Query.Environment" asp-items="Model.EnvironmentItems">
            </select>
        </div>
        <div class="field">
            <label>Chain</label>
            <select asp-for="Query.ChainId">
                <option value="">Select chain</option>
                @foreach (var item in Model.Chains)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </div>
        <div class="field actions">
            <button class="button" type="submit">Apply</button>
        </div>
    </form>
    <div class="actions" style="margin-top: 1rem;">
        <a class="button" asp-page="/Providers/Edit" asp-route-type="RealTime" asp-route-applicationId="@Model.Query.ApplicationId" asp-route-chainId="@Model.Query.ChainId" asp-route-environment="@Model.Query.Environment">Add RealTime</a>
        <a class="button" asp-page="/Providers/Edit" asp-route-type="Archive" asp-route-applicationId="@Model.Query.ApplicationId" asp-route-chainId="@Model.Query.ChainId" asp-route-environment="@Model.Query.Environment">Add Archive</a>
        <a class="button" asp-page="/Providers/Edit" asp-route-type="Tracing" asp-route-applicationId="@Model.Query.ApplicationId" asp-route-chainId="@Model.Query.ChainId" asp-route-environment="@Model.Query.Environment">Add Tracing</a>
        <a class="button secondary" asp-page="/Applications/Index">Applications</a>
        <a class="button secondary" asp-page="/Chains/Index">Chains</a>
        <a class="button secondary" asp-page="/ProvidersAdmin/Index">Providers</a>
        <a class="button secondary" asp-page="/RateLimits/Index">Rate Limits</a>
    </div>
</div>

<table>
    <thead>
        <tr>
            <th>Application</th>
            <th>Chain</th>
            <th>Type</th>
            <th>Provider</th>
            <th>Address</th>
            <th>Updated</th>
            <th>Probed</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@row.Application</td>
            <td>@row.Chain</td>
            <td>@row.Type</td>
            <td>@row.Provider</td>
            <td>@row.Address</td>
            <td>@row.UpdatedUtc</td>
            <td>@row.ProbedUtc</td>
            <td><a class="button secondary" asp-page="/Providers/Edit" asp-route-type="@row.Type" asp-route-id="@row.Id">Edit</a></td>
        </tr>
    }
    </tbody>
</table>
