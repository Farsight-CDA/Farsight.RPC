@page
@model Farsight.Rpc.Api.Pages.Applications.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Applications";
    ViewData["ActivePage"] = "Applications";
}

<div class="actions" style="margin-bottom: 1rem;">
    <a class="button secondary" asp-page="/Index">← Back to Home</a>
</div>

<div class="panel">
    <h1>Applications</h1>
    <form method="post" class="actions">
        <input asp-for="Name" />
        <button class="button" type="submit">Add</button>
    </form>
</div>

<table>
<thead><tr><th>Name</th><th style="text-align: right;">Actions</th></tr></thead>
<tbody>
@foreach (var item in Model.Items)
{
    <tr>
        <td>@item.Name</td>
        <td style="text-align: right;">
            <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display: inline;" onsubmit="return confirm('Delete this application?');">
                <button type="submit" class="button danger" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;">Remove</button>
            </form>
        </td>
    </tr>
}
</tbody>
</table>
