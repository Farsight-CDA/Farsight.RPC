@page
@model Farsight.RPC.Providers.Pages.IndexModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home";
    ViewData["ActivePage"] = "Home";
}

<div class="panel">
    <form method="post" id="selectionForm">
        <!-- Hidden fields to track previous values for change detection -->
        <input type="hidden" name="PreviousApplicationId" value="@Model.SelectedApplicationId" />
        <input type="hidden" name="PreviousChainId" value="@Model.SelectedChainId" />
        <input type="hidden" asp-for="ShowAddForm" />

        <!-- Step 1: Application Selection -->
        @if (Model.Applications.Count == 0)
        {
            <div class="message info">No applications available.</div>
            <a class="button" asp-page="/Applications/Index">+ Add New Application</a>
        }
        else
        {
            <div class="field" style="margin-bottom: 0.5rem;">
                <select asp-for="SelectedApplicationId" 
                        onchange="document.getElementById('selectionForm').submit()"
                        style="width: 100%;">
                    <option value="">Select Application</option>
                    @foreach (var app in Model.Applications)
                    {
                        <option value="@app.Id" selected="@(Model.SelectedApplicationId == app.Id ? "selected" : null)">@app.Name</option>
                    }
                </select>
            </div>

            @if (!Model.HasSelectedApplication)
            {
                <a class="add-new-link" asp-page="/Applications/Index">+ Add New Application</a>
            }
        }

        <!-- Step 2: Chain Selection (only show if App selected) -->
        @if (Model.HasSelectedApplication)
        {
            @if (Model.Chains.Count == 0)
            {
                <div class="message info" style="margin-top: 0.5rem;">No chains available.</div>
                <a class="button" asp-page="/Chains/Index" style="margin-top: 0.5rem;">+ Add New Chain</a>
            }
            else
            {
                <div class="field" style="margin-top: 0.5rem; margin-bottom: 0.5rem;">
                    <select asp-for="SelectedChainId" 
                            onchange="document.getElementById('selectionForm').submit()"
                            style="width: 100%;">
                        <option value="">Select Chain</option>
                        @foreach (var chain in Model.Chains)
                        {
                            <option value="@chain.Id" selected="@(Model.SelectedChainId == chain.Id ? "selected" : null)">@chain.Name</option>
                        }
                    </select>
                </div>

                @if (!Model.HasSelectedChain)
                {
                    <a class="add-new-link" asp-page="/Chains/Index">+ Add New Chain</a>
                }
            }
        }

        <!-- Step 3: Environment Selection (only show if Chain selected) -->
        @if (Model.HasSelectedChain)
        {
            <div class="field" style="margin-top: 0.5rem;">
                <select asp-for="SelectedEnvironment" 
                        onchange="document.getElementById('selectionForm').submit()"
                        style="width: 100%;">
                    <option value="">Select Environment</option>
                    @foreach (var env in Enum.GetValues<HostEnvironment>())
                    {
                        <option value="@env" selected="@(Model.SelectedEnvironment == env ? "selected" : null)">@env</option>
                    }
                </select>
            </div>
        }
    </form>

    <!-- Step 4: Results (only show if all selected) -->
    @if (Model.CanShowResults)
    {
        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #374151;">
            
            <!-- Probe Result Message -->
            @if (!string.IsNullOrEmpty(Model.ProbeMessage))
            {
                <div class="message @(Model.ProbeSucceeded ? "success" : "error")" style="margin-bottom: 1rem;">
                    @Model.ProbeMessage
                </div>
            }
            
            <!-- Add Provider Button or Inline Form -->
            @if (!Model.ShowAddForm)
            {
                <div class="actions" style="margin-bottom: 1rem;">
                    <a class="button" asp-page="/Index" 
                       asp-route-selectedApplicationId="@Model.SelectedApplicationId"
                       asp-route-selectedChainId="@Model.SelectedChainId"
                       asp-route-selectedEnvironment="@Model.SelectedEnvironment"
                       asp-route-showAddForm="true">+ Add Provider</a>
                </div>
            }
            else
            {
                <div class="panel" style="background: #111827; margin-bottom: 1rem;">
                    <form method="post" asp-page-handler="AddProvider">
                        <input type="hidden" asp-for="SelectedApplicationId" />
                        <input type="hidden" asp-for="SelectedChainId" />
                        <input type="hidden" asp-for="SelectedEnvironment" />
                        
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <select asp-for="NewProviderType" style="flex: 1; min-width: 120px;">
                                @foreach (var type in Enum.GetValues<RpcEndpointType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                            
                            <select asp-for="NewProviderId" style="flex: 2; min-width: 150px;" required>
                                <option value="">Select Provider</option>
                                @foreach (var provider in Model.ProvidersList)
                                {
                                    <option value="@provider.Id">@provider.Name</option>
                                }
                            </select>
                            
                            <input asp-for="NewAddress" placeholder="Address (https://...)" style="flex: 3; min-width: 200px;" required />
                            
                            <button type="submit" class="button">Save</button>
                            <a class="button secondary" asp-page="/Index" 
                               asp-route-selectedApplicationId="@Model.SelectedApplicationId"
                               asp-route-selectedChainId="@Model.SelectedChainId"
                               asp-route-selectedEnvironment="@Model.SelectedEnvironment">Cancel</a>
                        </div>
                    </form>
                </div>
            }

            @if (Model.Providers.Count == 0 && !Model.ShowAddForm)
            {
                <div class="message info">No providers configured for this selection.</div>
            }
            else if (Model.Providers.Count > 0)
            {
                <table style="margin-top: 0.5rem;">
                    <thead>
                        <tr>
                            <th>Address</th>
                            <th>Type</th>
                            <th>Updated</th>
                            <th>Probed</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var provider in Model.Providers)
                    {
                        <tr class="clickable-row" onclick="window.location.href='@Url.Page("/Providers/Edit", new { type = provider.Type, id = provider.Id })'">
                            <td style="font-family: monospace; font-size: 0.875rem;" title="@provider.Address">
                                @Model.ShortenAddress(provider.Address)
                            </td>
                            <td>@provider.Type</td>
                            <td style="white-space: nowrap;">@provider.UpdatedUtc.ToString("g")</td>
                            <td style="white-space: nowrap;">@(provider.ProbedUtc?.ToString("g") ?? "—")</td>
                            <td style="text-align: right;">
                                <form method="post" style="display: inline;" onclick="event.stopPropagation();">
                                    <input type="hidden" asp-for="SelectedApplicationId" />
                                    <input type="hidden" asp-for="SelectedChainId" />
                                    <input type="hidden" asp-for="SelectedEnvironment" />
                                    <button type="submit" 
                                            asp-page-handler="Probe" 
                                            asp-route-id="@provider.Id" 
                                            asp-route-type="@provider.Type"
                                            class="button secondary" 
                                            style="padding: 0.4rem 0.6rem; font-size: 0.875rem;"
                                            onclick="return confirm('Probe this provider?');">
                                        Probe
                                    </button>
                                </form>
                                <form method="post" style="display: inline; margin-left: 0.25rem;" onclick="event.stopPropagation();">
                                    <input type="hidden" asp-for="SelectedApplicationId" />
                                    <input type="hidden" asp-for="SelectedChainId" />
                                    <input type="hidden" asp-for="SelectedEnvironment" />
                                    <button type="submit" 
                                            asp-page-handler="Delete" 
                                            asp-route-id="@provider.Id" 
                                            asp-route-type="@provider.Type"
                                            class="button danger" 
                                            style="padding: 0.4rem 0.6rem; font-size: 0.875rem;"
                                            onclick="return confirm('Are you sure you want to delete this provider? This action cannot be undone.');">
                                        Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    }
</div>
