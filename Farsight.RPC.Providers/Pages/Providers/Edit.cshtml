@page "{id:guid?}"
@model Farsight.RPC.Providers.Pages.Providers.EditModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Input.Id.HasValue ? "Edit RPC Endpoint" : "New RPC Endpoint";
    ViewData["ActivePage"] = "Home";
}

<div class="actions" style="margin-bottom: 1rem;">
    <a class="button secondary" asp-page="/Index" 
       asp-route-selectedApplicationId="@Model.Input.ApplicationId"
       asp-route-selectedChainId="@Model.Input.ChainId"
       asp-route-selectedEnvironment="@Model.Input.Environment">← Back</a>
</div>

<div class="panel">
    <h2 style="margin-bottom: 1rem;">@(Model.Input.Id.HasValue ? "Edit RPC Endpoint" : "New RPC Endpoint")</h2>
    
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="message @(Model.StatusIsError ? "error" : "success")" style="margin-bottom: 1rem;">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ProbeMessage))
    {
        <div class="message @(Model.ProbeSucceeded ? "success" : "info")" style="margin-bottom: 1rem;">@Model.ProbeMessage</div>
    }

    <form method="post">
        @if (!ViewContext.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="message error" style="margin-bottom: 1rem;"></div>
        }
        
        <input asp-for="Input.Id" type="hidden" />
        
        <!-- Address (Full Width) -->
        <div class="field" style="margin-bottom: 1rem;">
            <label asp-for="Input.Address" style="display: block; margin-bottom: 0.25rem; color: #9ca3af; font-size: 0.875rem;">Address</label>
            <input asp-for="Input.Address" style="width: 100%; font-family: monospace;" placeholder="https://..." />
            <span asp-validation-for="Input.Address" class="validation-message"></span>
        </div>

        <!-- Provider & Type Row -->
        <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
            <div class="field" style="flex: 2;">
                <label style="display: block; margin-bottom: 0.25rem; color: #9ca3af; font-size: 0.875rem;">Provider</label>
                <select asp-for="Input.ProviderId" style="width: 100%;">
                    <option value="">Select provider</option>
                    @foreach (var item in Model.Providers)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.ProviderId" class="validation-message"></span>
            </div>
            <div class="field" style="flex: 1;">
                <label style="display: block; margin-bottom: 0.25rem; color: #9ca3af; font-size: 0.875rem;">Type</label>
                <select asp-for="Input.Type" asp-items="Model.TypeItems" style="width: 100%;"></select>
            </div>
        </div>

        <!-- App & Chain & Env Row -->
        <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
            <div class="field" style="flex: 2;">
                <label style="display: block; margin-bottom: 0.25rem; color: #9ca3af; font-size: 0.875rem;">Application</label>
                <select asp-for="Input.ApplicationId" style="width: 100%;">
                    <option value="">Select application</option>
                    @foreach (var item in Model.Applications)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.ApplicationId" class="validation-message"></span>
            </div>
            <div class="field" style="flex: 2;">
                <label style="display: block; margin-bottom: 0.25rem; color: #9ca3af; font-size: 0.875rem;">Chain</label>
                <select asp-for="Input.ChainId" style="width: 100%;">
                    <option value="">Select chain</option>
                    @foreach (var item in Model.Chains)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
                <span asp-validation-for="Input.ChainId" class="validation-message"></span>
            </div>
            <div class="field" style="flex: 1;">
                <label style="display: block; margin-bottom: 0.25rem; color: #9ca3af; font-size: 0.875rem;">Environment</label>
                <select asp-for="Input.Environment" asp-items="Model.EnvironmentItems" style="width: 100%;"></select>
            </div>
        </div>

        <!-- Archive-specific fields -->
        @if (Model.Input.Type == RpcEndpointType.Archive)
        {
            <div style="background: #111827; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                <div style="color: #9ca3af; font-size: 0.875rem; margin-bottom: 0.5rem;">Archive Settings</div>
                <div style="display: flex; gap: 0.5rem;">
                    <div class="field" style="flex: 1;">
                        <label style="display: block; margin-bottom: 0.25rem; color: #6b7280; font-size: 0.75rem;">Indexer Step</label>
                        <input asp-for="Input.IndexerStepSize" type="number" style="width: 100%;" />
                        <span asp-validation-for="Input.IndexerStepSize" class="validation-message"></span>
                    </div>
                    <div class="field" style="flex: 1;">
                        <label style="display: block; margin-bottom: 0.25rem; color: #6b7280; font-size: 0.75rem;">DEX Step</label>
                        <input asp-for="Input.DexIndexStepSize" type="number" style="width: 100%;" />
                        <span asp-validation-for="Input.DexIndexStepSize" class="validation-message"></span>
                    </div>
                    <div class="field" style="flex: 1;">
                        <label style="display: block; margin-bottom: 0.25rem; color: #6b7280; font-size: 0.75rem;">Block Offset</label>
                        <input asp-for="Input.IndexBlockOffset" type="number" style="width: 100%;" />
                        <span asp-validation-for="Input.IndexBlockOffset" class="validation-message"></span>
                    </div>
                </div>
            </div>
        }

        <!-- Tracing-specific fields -->
        @if (Model.Input.Type == RpcEndpointType.Tracing)
        {
            <div style="background: #111827; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
                <div style="color: #9ca3af; font-size: 0.875rem; margin-bottom: 0.5rem;">Tracing Settings</div>
                <div class="field">
                    <label style="display: block; margin-bottom: 0.25rem; color: #6b7280; font-size: 0.75rem;">Tracing Mode</label>
                    <select asp-for="Input.TracingMode" asp-items="Model.TracingModeItems" style="width: 100%;"></select>
                    <span asp-validation-for="Input.TracingMode" class="validation-message"></span>
                </div>
            </div>
        }

        <!-- Actions -->
        <div class="actions" style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #374151;">
            <button class="button" type="submit" style="min-width: 100px;">Save</button>
            <button class="button secondary" type="submit" asp-page-handler="Probe" style="min-width: 100px;">Probe</button>
            @if (Model.Input.Id.HasValue)
            {
                <button class="button danger" type="submit" asp-page-handler="Delete" onclick="return confirm('Permanently delete this RPC endpoint?');" style="margin-left: auto;">Delete</button>
            }
        </div>
    </form>
</div>
